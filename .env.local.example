# Supabase
NEXT_PUBLIC_SUPABASE_URL=your-supabase-url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Site URL
NEXT_PUBLIC_SITE_URL=https://zapitpestmelbourne.com.au

# Google Tag Manager container ID — staging and production should use separate
# containers. If unset, falls back to the prior build's container ID
# (see comment in src/lib/constants.ts). Replace before launch.
NEXT_PUBLIC_GTM_ID=GTM-XXXXXXX

# WhatConverts — Lead API credentials.
# Token: whatconverts.com → Settings → Tracking → API Access → generate a
# write-only "Web Tracking" token (never a read/admin token). Profile ID is
# the numeric Zap It profile ID in the WhatConverts dashboard URL.
# Both must be set for ContactForm.tsx to POST leads to WhatConverts; if
# unset the form still works and GA4 events still fire — WC call is skipped.
NEXT_PUBLIC_WHATCONVERTS_TOKEN=your-whatconverts-web-tracking-token
NEXT_PUBLIC_WHATCONVERTS_PROFILE_ID=171358
