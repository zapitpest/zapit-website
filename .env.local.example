# Supabase
NEXT_PUBLIC_SUPABASE_URL=your-supabase-url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Site URL
NEXT_PUBLIC_SITE_URL=https://zapitpestmelbourne.com.au

# Google Tag Manager container ID — staging and production should use separate
# containers. If unset, falls back to the prior build's container ID
# (see comment in src/lib/constants.ts). Replace before launch.
NEXT_PUBLIC_GTM_ID=GTM-XXXXXXX
