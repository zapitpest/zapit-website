.zapit-tabs-section {
    color: #153a8a;
    padding: 48px 0;
    font-family: 'Roboto', Arial, sans-serif;
    max-width: 1200px;
    width: 90vw;
    margin: 0 auto;
  }
  .zapit-tabs-container {
    display: flex;
    flex-direction: column;
    width: 100%;
    background: #fff;
    border-radius: 12px;
    box-shadow: 0 8px 32px rgba(0,0,0,0.10);
    overflow: hidden;
    padding-bottom: 0;
  }
  .zapit-content-row {
    display: flex;
    flex-direction: row;
    align-items: center;
    padding: 56px 48px 32px 48px;
    background: #f7faf9;
    gap: 48px;
  }
  .zapit-content-col {
    flex: 1;
    display: flex;
    flex-direction: column;
    justify-content: center;
  }
  .zapit-content-image {
    flex: 1;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .zapit-content-image img {
    max-width: 400px;
    width: 100%;
    border-radius: 12px;
    box-shadow: 0 2px 12px rgba(0,0,0,0.07);
  }
  .zapit-tab-content {
    display: none;
    flex-direction: column;
    justify-content: center;
    width: 100%;
    animation: fadeIn 0.4s;
