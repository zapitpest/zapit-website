    min-width: 300px;
    max-width: 370px;
    padding: 38px 28px 32px 28px;
    box-shadow: 0 8px 32px rgba(0,0,0,0.10);
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    color: #222;
    border: 1.5px solid #e6f9ed;
    transition: transform 0.18s, box-shadow 0.18s, border 0.18s;
  }
  .custom-step-box:hover {
    transform: translateY(-6px) scale(1.02);
    box-shadow: 0 16px 40px rgba(13,196,41,0.13);
    border: 1.5px solid #0DC429;
  }
  .custom-step-box.step1 {}
  .custom-step-box.step2 {}
  .custom-step-box.step3 {}
  
  /* Number styling */
  .step-header-row {
    display: flex;
    align-items: flex-end;
    gap: 16px;
