.custom-steps-section {
    max-width: 1300px;
    margin: 0 auto 40px auto;
    padding: 30px 10px;
    border-radius: 8px;
  
  }
  
  /* Header styling */
  .custom-steps-header {
    text-align: center;
    margin-bottom: 30px;
  }
  .custom-steps-header h2 {
    font-size: 28px;
    margin-bottom: 10px;
    font-weight: 700;
    color: #222;
  }
  .custom-steps-header span {
    color: #0DC429;
  }
  .custom-steps-header p {
    font-size: 1.2em;
    color: #444;
  }
  
  /* Card row */
  .custom-steps-row {
    display: flex;
    flex-direction: row;
    gap: 22px;
    flex-wrap: nowrap;
    justify-content: center;
  }
  
  /* Card styles */
  .custom-step-box {
    background: #fff;
    border-radius: 18px;
    flex: 1 1 320px;
    min-width: 300px;
    max-width: 370px;
    padding: 38px 28px 32px 28px;
    box-shadow: 0 8px 32px rgba(0,0,0,0.10);
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    color: #222;
    border: 1.5px solid #e6f9ed;
    transition: transform 0.18s, box-shadow 0.18s, border 0.18s;
  }
  .custom-step-box:hover {
    transform: translateY(-6px) scale(1.02);
    box-shadow: 0 16px 40px rgba(13,196,41,0.13);
    border: 1.5px solid #0DC429;
  }
  .custom-step-box.step1 {}
  .custom-step-box.step2 {}
  .custom-step-box.step3 {}
  
  /* Number styling */
  .step-header-row {
    display: flex;
    align-items: flex-end;
    gap: 16px;
    margin-bottom: 10px;
  }
  .step-number {
    font-size: 2.2em;
    font-weight: 800;
    color: #0DC429;
    text-shadow: 0 2px 8px #e6f9ed;
    margin-bottom: 0;
   
  }
  .step-title {
    font-size: 1.8em;
    font-weight: 700;
    color: #222 !important;
    line-height: 1.1;
    margin: 0;
  }
  .step-desc {
    font-size: 18px;
    margin-top: 26px;
    color: #444;
    line-height: 1.3;

  }
  .step-desc strong {
    display: block;
    margin-bottom: 7px;
    font-size: 1.05em;
    font-weight: 400;
    color: #0DC429;
  }
  
  /* Responsive adjustments */
  @media (max-width: 900px) {
    .custom-steps-row {
      flex-direction: column;
      gap: 24px;
      flex-wrap: wrap;
    }
    .custom-step-box {
      max-width: 100%;
    }
    .step-title {
      font-size: 1.15em;
    }
    .step-number {
      font-size: 1.5em;
    }
  }

